# =============================================================================
# WE-LAB COSMETICS - Variables d'environnement Docker
# =============================================================================
# Copier ce fichier vers .env et adapter les valeurs si nécessaire
# cp .env.example .env

# -----------------------------------------------------------------------------
# UTILISATEUR (important pour les permissions Linux)
# -----------------------------------------------------------------------------
# Récupérer avec: id -u (USERID) et id -g (GROUPID)
USERID=1000
GROUPID=1000

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_USER=welab
POSTGRES_PASSWORD=welab123
POSTGRES_DB=welab_db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# PORTS DES APPLICATIONS
# -----------------------------------------------------------------------------
SYMFONY_PORT=8000
ANGULAR_PORT=4200
ADMINER_PORT=8080

# -----------------------------------------------------------------------------
# CONFIGURATION SYMFONY (à mettre dans backend/.env)
# -----------------------------------------------------------------------------
# DATABASE_URL="postgresql://welab:welab123@postgres:5432/welab_db?serverVersion=16&charset=utf8"
