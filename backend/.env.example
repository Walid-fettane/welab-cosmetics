# =============================================================================
# We-Lab Cosmetics - Modele de configuration backend Symfony
# =============================================================================
# Ce fichier est un MODELE. Le vrai backend/.env est genere automatiquement
# par start.sh a la racine du projet, qui remplace les deux placeholders
# __APP_SECRET_PLACEHOLDER__ et __JWT_PASSPHRASE_PLACEHOLDER__ par des
# valeurs aleatoires (openssl rand -hex). Ne jamais commit le .env reel :
# il est dans backend/.gitignore.
# =============================================================================

###> symfony/framework-bundle ###
# APP_ENV : environnement Symfony (dev, prod ou test). En "dev" les erreurs
# sont affichees en clair, ce qui aide pendant le developpement.
APP_ENV=dev

# APP_SECRET : cle secrete utilisee par Symfony pour signer les sessions,
# les jetons CSRF, etc. Doit etre aleatoire et unique a chaque installation.
APP_SECRET=__APP_SECRET_PLACEHOLDER__

# APP_SHARE_DIR : dossier ou Symfony peut stocker des fichiers partages
# (uploads, exports, etc.) relatif a la racine du projet.
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# DEFAULT_URI : URL par defaut utilisee par les commandes CLI quand elles
# doivent generer des liens absolus (par exemple : envoi d'emails).
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# DATABASE_URL : URL de connexion PostgreSQL au format DSN
# Format : postgresql://utilisateur:motdepasse@hote:port/nom_bdd?options
# Le nom d'hote "postgres" est celui du service docker-compose.
DATABASE_URL="postgresql://welab:welab123@postgres:5432/welab_db?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# MESSENGER_TRANSPORT_DSN : ou Symfony envoie les messages asynchrones.
# Ici "doctrine" stocke les messages dans une table de la base de donnees.
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# MAILER_DSN : configuration de l'envoi d'emails. "null://null" desactive
# l'envoi reel : utile en developpement et pour les tests.
MAILER_DSN=null://null
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
# JWT_SECRET_KEY / JWT_PUBLIC_KEY : chemins vers les cles RSA generees par
# la commande "lexik:jwt:generate-keypair" (start.sh s'en charge automatiquement).
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# JWT_PASSPHRASE : passphrase qui chiffre la cle privee JWT. Doit etre
# identique a la passphrase utilisee lors de la generation des cles.
JWT_PASSPHRASE=__JWT_PASSPHRASE_PLACEHOLDER__
###< lexik/jwt-authentication-bundle ###
